# ============================================
# CONFIGURACIÓN DE API - Robot ESP32
# ============================================

# 🔑 API KEY DE GOOGLE GEMINI (REQUERIDO)
# Obtén tu API key en: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=tu_api_key_aqui

# 🤖 MODELO DE GEMINI
# Opciones: gemini-1.5-flash, gemini-1.5-pro, gemini-2.0-flash-exp
# Recomendado: gemini-1.5-flash (más rápido y económico)
GEMINI_MODEL=gemini-1.5-flash

# 🗣️ IDIOMA DEL TEXT-TO-SPEECH
# Códigos ISO 639-1: es (español), en (inglés), fr (francés), etc.
TTS_LANG=es

# 🌐 CONFIGURACIÓN DEL SERVIDOR (OPCIONAL)
# Puerto en el que corre la API
API_PORT=8000

# Host para el servidor (0.0.0.0 permite conexiones externas)
API_HOST=0.0.0.0

# 📊 CONFIGURACIÓN DE LOGS (OPCIONAL)
# Nivel de logs: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 🎭 PERSONALIDAD DEL ROBOT (OPCIONAL)
# Si se define aquí, sobrescribe la personalidad por defecto
# PERSONALIDAD="Eres un asistente robot amigable y servicial"

# 💾 LÍMITE DE HISTORIAL (OPCIONAL)
# Número máximo de mensajes a recordar por conversación
MAX_HISTORIAL=12

# ⏱️ TIMEOUTS (OPCIONAL - en segundos)
# Timeout para requests a Gemini API
GEMINI_TIMEOUT=30

# Timeout para generación de TTS
TTS_TIMEOUT=15
